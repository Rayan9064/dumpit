{
  "manifest_version": 3,
  "name": "DumpIt",
  "version": "1.0.0",
  "description": "Save pages, selections and links to your DumpIt AI knowledge vault.",
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["src/content/content-script.ts"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
